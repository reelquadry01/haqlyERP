# HAQLY ERP - Environment Configuration
# Author: Quadri Atharu

# Server
SERVER_PORT=8100
SERVER_HOST=0.0.0.0

# Database
DATABASE_URL=postgresql://haqly:haqly@localhost:5432/haqly_erp

# Redis
REDIS_URL=redis://localhost:6379

# JWT — WARNING: JWT_SECRET MUST be changed from the default in production!
JWT_SECRET=change-me-in-production
JWT_EXPIRATION_HOURS=24
JWT_REFRESH_EXPIRATION_DAYS=7

# CORS
CORS_ORIGINS=http://localhost:3001,tauri://localhost

# NRS/FIRS E-Invoicing
EINVOICING_FIRS_BASE_URL=https://einvoice.firs.gov.ng
EINVOICING_FIRS_API_KEY=
EINVOICING_FIRS_API_SECRET=
EINVOICING_FIRS_ENVIRONMENT=SANDBOX

# Ollama (Local LLM)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# Python AI Engine
PYTHON_ENGINE_URL=http://localhost:8200
NAIJA_ENGINE_ENV=development

# OCR
TESSERACT_PATH=tesseract

# Tauri Auto-Update Signing (Ed25519)
# Generate keypair: bash scripts/generate-update-keys.sh
UPDATES_PRIVATE_KEY_PATH=./keys/update-private.pem

# Windows Code Signing
# Obtain a code signing certificate from a trusted CA (DigiCert, Sectigo, GlobalSign)
# Install the certificate in Windows Certificate Store, then set the thumbprint below
# To find thumbprint: certutil -store My | findstr -i "sha1"
WINDOWS_CERTIFICATE_THUMBPRINT=
# Timestamp server for code signing
WINDOWS_TIMESTAMP_URL=http://timestamp.digicert.com
